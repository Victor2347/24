{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Stores customer information for searching and comparison.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Customer name"
        },
        "customerId": {
          "type": "string",
          "description": "Customer ID (客代)"
        },
        "taxId": {
          "type": "string",
          "description": "Tax ID (統編)"
        },
        "address": {
          "type": "string",
          "description": "Customer address"
        },
        "createdBy": {
          "type": "string",
          "description": "User ID who created the record"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["name", "customerId", "taxId", "address", "createdBy", "createdAt"]
    },
    "ComparisonLog": {
      "title": "Comparison Log",
      "description": "Logs comparison events for statistics.",
      "type": "object",
      "properties": {
        "customerId": {
          "type": "string",
          "description": "Customer ID that was matched"
        },
        "matchedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Match timestamp"
        },
        "matchedBy": {
          "type": "string",
          "description": "User ID who performed the comparison"
        }
      },
      "required": ["customerId", "matchedAt", "matchedBy"]
    }
  },
  "firestore": {
    "customers": {
      "schema": "Customer",
      "description": "Collection of customer records."
    },
    "comparisonLogs": {
      "schema": "ComparisonLog",
      "description": "Collection of comparison logs for statistics."
    }
  }
}
